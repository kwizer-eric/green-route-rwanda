VITE_SUPABASE_URL=https://your-project.supabase.co

# Dashboard → Settings → API keys → use "anon" (eyJ...) OR "publishable" (sb_publishable_...)
# If login shows "Failed to fetch", try the legacy anon JWT key instead.
VITE_SUPABASE_ANON_KEY=your-anon-key

# For npm run db:migrate — Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=

# Session pooler URI from Dashboard → Connect (optional; speeds up db:migrate)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-central-2.pooler.supabase.com:5432/postgres

# Supabase Dashboard → Authentication → URL Configuration (for local dev):
# Site URL: http://localhost:5173
# Redirect URLs: http://localhost:5173/**
