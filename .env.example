VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For npm run db:migrate — Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=

# Or paste the full connection string (Session mode URI from Dashboard → Connect)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: for `npm run db:push` via Supabase CLI
# SUPABASE_ACCESS_TOKEN=
